<Page x:Class="ReGraphik.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6" Title="Dashboard">
    <Border Background="White" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
        </Border.Effect>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="⊞" FontSize="48" HorizontalAlignment="Center" Foreground="#2563EB"/>
            <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold"
                       Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="Em desenvolvimento" FontSize="14" Foreground="#94A3B8"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</Page>