<Page x:Class="ReGraphik.Views.Pages.ResiduosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#F8FAFC" Title="Cadastro de Resíduos">

    <Page.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputControlStyle" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Cadastro de Resíduos" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="24">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.05" Color="#000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Novo Resíduo" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Tipo de Material" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="CboTipoMaterial" Style="{StaticResource InputControlStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="Selecione o tipo de material" Foreground="#94A3B8" IsEnabled="False"/>

                                <ComboBoxItem Content="Papel Offset"/>
                                <ComboBoxItem Content="Papel Couché"/>
                                <ComboBoxItem Content="Papel Kraft"/>
                                <ComboBoxItem Content="Papelão"/>
                                <ComboBoxItem Content="Adesivo Vinil"/>
                                <ComboBoxItem Content="Lona"/>
                                <ComboBoxItem Content="PVC"/>
                                <ComboBoxItem Content="Acrílico"/>
                                <ComboBoxItem Content="Outro"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="Especificação" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="TxtEspecificacao" Style="{StaticResource InputControlStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Origem" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="CboOrigem" Style="{StaticResource InputControlStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="Selecione a origem" Foreground="#94A3B8" IsEnabled="False"/>

                                <ComboBoxItem Content="Restos de Corte"/>
                                <ComboBoxItem Content="Sobra de Impressão"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="Projeto/Cliente de Origem" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="TxtProjetoOrigem" Style="{StaticResource InputControlStyle}"/>
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Quantidade" Style="{StaticResource FieldLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtQuantidade" Style="{StaticResource InputControlStyle}"/>
                                    <ComboBox Grid.Column="1" Width="60" Style="{StaticResource InputControlStyle}" SelectedIndex="0" BorderThickness="0,1,1,1">
                                        <ComboBoxItem Content="kg"/>
                                        <ComboBoxItem Content="un"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Data" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker x:Name="DpData" Height="38" Padding="5"  VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="Condição" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="CboCondicao" Style="{StaticResource InputControlStyle}" SelectedIndex="0" SelectionChanged="CboCondicao_SelectionChanged">
                                <ComboBoxItem Content="Selecione o tipo de condição" Foreground="#94A3B8" IsEnabled="False"/>
                                <ComboBoxItem Content="Ótima (como novo)"/>
                                <ComboBoxItem Content="Regular / Usado"/>
                                <ComboBoxItem Content="Danificado"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Text="Dimensões (se aplicável)" Style="{StaticResource FieldLabelStyle}"/>

                        <Grid Grid.Row="4" Grid.Column="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDimensaoX" Style="{StaticResource InputControlStyle}" Text="Comprimento" Foreground="#94A3B8" TextChanged="TxtDimensaoX_TextChanged"/>
                            <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,1,1" Width="40" Height="38">
                                <TextBlock Text="cm" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#64748B"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4" Grid.Column="2" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDimensaoY" Style="{StaticResource InputControlStyle}" Text="Largura" Foreground="#94A3B8"/>
                            <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,1,1" Width="40" Height="38">
                                <TextBlock Text="cm" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#64748B"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
                            <TextBlock Text="Observações" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="TxtObservacoes" Style="{StaticResource InputControlStyle}" Height="80" 
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="8"
                                     Text="Observações adicionais sobre o material" Foreground="#94A3B8"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="Foto do Material (opcional)" Style="{StaticResource FieldLabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnEscolherArquivo" Content="Escolher Arquivo" Click="BtnEscolherArquivo_Click"
                                        Padding="12,0" Height="38" Background="#F1F5F9" BorderBrush="#CBD5E1" Foreground="#1E293B"/>
                                <TextBox Grid.Column="1" x:Name="TxtNomeArquivo" Style="{StaticResource InputControlStyle}" 
                                         IsReadOnly="True" Text="Video com Legenda.mp4" Margin="0,0,0,0" Background="White"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnLimpar" Content="Limpar" Click="BtnLimpar_Click"
                                    Width="100" Height="40" Background="#F1F5F9" BorderBrush="#CBD5E1" 
                                    Foreground="#1E293B" FontWeight="SemiBold" Margin="0,0,12,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="BtnSalvarResiduo" Content="Salvar Resíduo" Click="BtnSalvarResiduo_Click"
                                    Width="140" Height="40" Background="#2563EB" BorderThickness="0" 
                                    Foreground="White" FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>
        </Grid>

    </ScrollViewer>
</Page>