<Page
    x:Class="ReGraphik.Views.Pages.MapaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F3F4F6"
    Title="Mapa de Pontos de Coleta">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho e controles -->
        <Border Grid.Row="0" Background="White" CornerRadius="12"
                Padding="20,14" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Mapa de Pontos de Coleta" FontSize="20"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Visualize os pontos de coleta de resíduos no mapa"
                               FontSize="12" Foreground="#64748B" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Buscar cidade:" FontSize="13" Foreground="#64748B"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <TextBox x:Name="TxtCidade" Width="160" Height="36"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="10,0" FontSize="13" VerticalContentAlignment="Center"
                                 Text="São Paulo"/>
                    </Border>
                    <Button Content="Buscar"
                            Height="36" Width="80" Margin="8,0,0,0"
                            Background="#2563EB" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Click="BtnBuscar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Área principal: mapa + lista lateral -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de pontos -->
            <Border Grid.Column="0" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0"
                            Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Pontos encontrados" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1E293B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <Border Background="#DBEAFE" CornerRadius="10"
                                    Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtContagem" Text="0" FontSize="11"
                                           FontWeight="Bold" Foreground="#2563EB"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaPontos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,12" BorderBrush="#F1F5F9"
                                            BorderThickness="0,0,0,1" Cursor="Hand"
                                            MouseLeftButtonDown="PontoItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36"
                                                    Background="#DBEAFE" CornerRadius="8"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="📍" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding NomePonto}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="#1E293B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Cidade}" FontSize="11"
                                                           Foreground="#64748B" Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                                <Border Background="#D1FAE5" CornerRadius="4"
                                                        Padding="6,2" Margin="0,4,0,0"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding ResiduosAceitos}"
                                                               FontSize="10" Foreground="#065F46"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Estado vazio -->
                    <StackPanel x:Name="EstadoVazio" Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Visible">
                        <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Busque uma cidade" FontSize="13" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="para ver os pontos" FontSize="13" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Carregando -->
                    <StackPanel x:Name="EstadoCarregando" Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock Text="⏳" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Buscando pontos..." FontSize="13" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Mapa WebBrowser com Leaflet -->
            <Border Grid.Column="2" CornerRadius="12" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                </Border.Effect>
                <Grid>
                    <WebBrowser x:Name="MapaBrowser"
                                Navigated="MapaBrowser_Navigated"/>

                    <!-- Overlay inicial -->
                    <Border x:Name="MapaPlaceholder" Background="White" CornerRadius="12">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🗺" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="Mapa de Coleta" FontSize="18" FontWeight="Bold"
                                       Foreground="#1E293B" HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                            <TextBlock Text="Digite uma cidade e clique em Buscar"
                                       FontSize="13" Foreground="#94A3B8"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>