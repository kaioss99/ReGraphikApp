<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ReGraphik"
    Height="720"
    Width="1200">

    <Grid>

        <TabControl>

            <!-- DASHBOARD -->
            <TabItem Header="Dashboard">

                <Grid>

                    <TextBlock
                        Text="Dashboard"
                        FontSize="30"
                        FontWeight="Bold"/>

                </Grid>

            </TabItem>

            <!-- RESÍDUOS -->
            <TabItem Header="Resíduos">

                <StackPanel Margin="20">

                    <TextBox
                        Height="35"
                        Text="{Binding NomeResiduo}" />

                    <Button
                        Height="35"
                        Margin="0,10,0,0"
                        Content="Salvar"
                        Command="{Binding SalvarResiduoCommand}" />

                    <ListBox
                        Margin="0,10,0,0"
                        ItemsSource="{Binding Residuos}" />

                </StackPanel>

            </TabItem>

            <!-- PONTOS -->
            <TabItem Header="Pontos de Coleta">

            </TabItem>

            <!-- MAPA -->
            <TabItem Header="Mapa">

            </TabItem>

        </TabControl>

    </Grid>
</Window>