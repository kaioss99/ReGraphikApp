<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    MinHeight="600"
    MinWidth="960"
    WindowStartupLocation="CenterScreen"
    Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnAtivo" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#022654"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#093e75">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="20,24,20,20">    
                    <TextBlock.Inlines>
                        <Run Text="♻️"/>
                        <Run Text="ReGraphik"/>
                    </TextBlock.Inlines>
                </TextBlock>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard"
                            Style="{StaticResource NavBtnAtivo}"
                            Click="Dashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞ " FontSize="15"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnResiduos"
                            Style="{StaticResource NavBtn}"
                            Click="Residuos_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♻ " FontSize="15"/>
                            <TextBlock Text="Cadastrar Resíduos"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEstoqueReverso"
                            Style="{StaticResource NavBtn}"
                            Click="EstoqueReverso_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍 " FontSize="15"/>
                            <TextBlock Text="Estoque Reverso"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnMapa"
                            Style="{StaticResource NavBtn}"
                            Click="Mapa_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗺 " FontSize="15"/>
                            <TextBlock Text="Mapa"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRelatorios"
                            Style="{StaticResource NavBtn}"
                            Click="Relatorios_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊 " FontSize="15"/>
                            <TextBlock Text="Relatórios"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame"
               Grid.Column="1"
               Margin="20"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>